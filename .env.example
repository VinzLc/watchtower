# Port du backend Fastify (choisis un port libre)
PORT=4010

# Port du dashboard Vite (choisis un port libre)
WEB_PORT=5180

# Origine autorisée pour le dashboard (CORS)
WEB_ORIGIN=http://localhost:5180

# Données de marché : aucune clé requise
#  - Crypto : API publique Binance
#  - Actions : API publique Yahoo Finance

# Ingestion des briefings de James (script `pnpm --filter @watchtower/server run ingest`)
# Clé API Anthropic — https://console.anthropic.com
# Utilisée uniquement en local pour structurer le texte de James (jamais en CI/prod).
ANTHROPIC_API_KEY=
