{
  "name": "watchtower",
  "version": "0.1.0",
  "private": true,
  "description": "Surveille actions & crypto pour repérer les bons moments d'achat/vente",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @watchtower/server run dev",
    "dev:web": "pnpm --filter @watchtower/web run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
